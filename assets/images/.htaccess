#Disable PHP execution
php_flag engine off

#block any script files from being accessed
<FilesMatch "(?i)\.(php|php3|php4|php5|phtml|pl|py|jsp|asp|sh|cgi)$">
  Order Allow,Deny
  Deny from all
</FilesMatch>

# Allow only image types
<FilesMatch "(?i)\.(jpg|jpeg|png|gif|webp)$">
  Order Allow,Deny
  Allow from all
</FilesMatch>